{
	"manifest_version": 2,
	"name": "BibFix",
	"version": "0.1.0",
	"description": "Bibliographic data optimization for Zotero",
	"homepage_url": "https://github.com/bibfix/zotero-bibfix",
	"author": "Andre Krischer",
	"icons": {
		"48": "content/icons/icon48.png",
		"96": "content/icons/icon96.png"
	},
	"applications": {
		"zotero": {
			"id": "bibfix@zotero-plugin.org",
			"strict_min_version": "7.999",
			"strict_max_version": "9.*"
		}
	}
}
